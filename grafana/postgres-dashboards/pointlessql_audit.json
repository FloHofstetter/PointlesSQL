            "uid": "pointlessql-postgres"
          },
          "rawSql": "SELECT CASE WHEN COUNT(*) = 0 THEN 100.0 ELSE 100.0 * SUM(CASE WHEN outcome='delivered' THEN 1 ELSE 0 END)::float8 / COUNT(*) END AS delivery_pct FROM governance_events WHERE fired_at > NOW() - INTERVAL '1 hour' AND (0 IN ($workspace) OR workspace_id IN ($workspace))",
