    {
      "id": 8,
      "type": "barchart",
      "title": "Top mutating principals (rows written)",
      "description": "Sum of rows_affected for merge/write_table operations, grouped by principal. Filtered by `$workspace` dropdown.",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "pointlessql-postgres"
      },
      "targets": [
        {
          "refId": "A",
