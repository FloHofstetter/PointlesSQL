    {
      "id": 6,
      "type": "timeseries",
      "title": "Reject-rate vs 7-day baseline",
      "description": "Daily rejects (lineage_row_rejects) plus a 7-day trailing average baseline. Spikes above baseline warrant a look. Filtered by `$workspace` dropdown.",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "pointlessql-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "pointlessql-postgres"
          },
          "rawSql": "SELECT date(created_at) AS time, COUNT(*) AS rejects FROM lineage_row_rejects WHERE $__timeFilter(created_at) AND (0 IN ($workspace) OR lineage_row_rejects.workspace_id IN ($workspace)) GROUP BY date(created_at) ORDER BY 1",
          "format": "time_series"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "postgres",
            "uid": "pointlessql-postgres"
          },
          "rawSql": "SELECT d.day AS time, (SELECT (COUNT(*)::float8 / 7.0) FROM lineage_row_rejects r WHERE date(r.created_at) > (d.day - INTERVAL '7 days') AND date(r.created_at) <= date(d.day) AND (0 IN ($workspace) OR r.workspace_id IN ($workspace))) AS baseline_7d_avg FROM (SELECT DISTINCT date(created_at) AS day FROM lineage_row_rejects WHERE $__timeFilter(created_at) AND (0 IN ($workspace) OR lineage_row_rejects.workspace_id IN ($workspace))) d ORDER BY 1",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "noValue": "0",
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "baseline_7d_avg"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    6,
                    4
                  ]
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 1
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
