            "type": "postgres",
            "uid": "pointlessql-postgres"
          },
          "rawSql": "SELECT COALESCE(r.principal, '<unknown>') AS principal, COALESCE(SUM(o.rows_affected), 0) AS total_rows FROM agent_runs r JOIN agent_run_operations o ON o.agent_run_id = r.id WHERE o.op_name IN ('merge', 'write_table') AND $__timeFilter(r.started_at) AND (0 IN ($workspace) OR r.workspace_id IN ($workspace)) GROUP BY r.principal ORDER BY total_rows DESC LIMIT 10",
          "format": "table"
        }
      ],
