__pycache__/
*.py[cod]
.venv/
.env
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.mypy_cache/
.pyright/
node_modules/

# Biome local cache (in case future versions write one alongside biome.json)
.biome/

*.db
*.db-shm
*.db-wal
*.sqlite
.ipynb_checkpoints/

# mkdocs build output — site is generated, never committed.
site/

# Runtime state from docker-compose stacks — never commit seeded
# Delta files or the Playwright MCP artefact directory.
warehouse/
.playwright-mcp/

# Playwright-MCP screenshots dropped into the repo root during live
# replays (ux-*, sprint*, compare-*, dashboard*, non-admin*,
# run-compare, etc.). Ephemeral debug artefacts; the playbooks are
# the source of truth, not these PNGs.
/*.png

# Papermill job output (Sprint 24). The executor writes per-run
# ipynb copies into notebooks/runs/ — ephemeral artefacts tied to
# a specific run id, never tracked. The seeded playbook notebooks
# are regenerated on demand by scripts/seed-e2e.py; the canonical
# content lives in the script, not the workspace.
notebooks/runs/
notebooks/smoke_papermill.ipynb
notebooks/smoke_typed_params.ipynb
notebooks/bad_papermill.ipynb

# Workspace scratch notebooks (Sprint 69 housekeeping). Anything
# named ``scratch*`` under ``notebooks/`` is per-developer playground
# state — created by replays / experiments, never tracked.  Also
# ignore ``playbook_upload.ipynb`` which the Sprint-23 jobs/upload
# playbook drops into the workspace.
notebooks/scratch*
notebooks/playbook_upload.ipynb

# Phase 12.12 — the notebook browser editor and its entire vendored
# JS stack (Monaco / KaTeX / markdown-it / markdown-it-texmath /
# jsdiff) were removed in favour of a server-side Jinja run-detail
# view. The ``frontend/js/vendor/`` directory no longer exists and
# the corresponding ``scripts/vendor-*.sh`` fetchers were deleted.

# Phase 21.0 — MLflow subprocess artifacts (cwd-local).
mlflow.pid
mlflow.db
mlflow.db-shm
mlflow.db-wal
mlflow_artifacts/

# Phase 21.5 — MLflow tracking-store + registered-model artifacts
mlruns/
model_artifacts/

# Phase-2 full-stack-demo runtime artefacts
notebooks/full_stack_demo_data/

# Local SQLite store (BUG-grand-09 path anchor still emits these in repo root).
pointlessql.db
pointlessql.db-shm
pointlessql.db-wal

# Local agent / IDE state — Claude Code workspace, never committed.
.claude/

# Phase 31 local benchmarking output — ``scripts/bench_test_suite.sh``
# writes timestamped wall-clock files here.  Per-machine, never committed.
.bench/

# Replay-session diagnostic logs — dropped in the repo root by
# Playwright-MCP / browser-replay sessions.  Always per-session,
# never useful in history.
*.log

# Phase 121.9 — Playwright-MCP replay-session output directories.
# Pattern: ``phase{NN}-replay/`` at repo root, mirroring the per-
# phase playbook structure under ``docs/e2e-walkthroughs/``.  The
# canonical playbook lives in docs; per-session PNG dumps +
# REPLAY_REPORT.md are ephemeral debugging artefacts, never tracked.
phase*-replay/

# Local canvas UX-audit screenshot dumps — per-session, never tracked.
.canvas-ux-audit/
