# PointlesSQL environment variables.
#
# Copy to .env and edit. All POINTLESSQL_* variables map to
# pointlessql.settings.Settings sub-model fields via pydantic-settings.
# Sprint 45 split the flat Settings into nine sub-models, each with
# its own env_prefix — see CHANGELOG.md for the full rename map.

# ---------------------------------------------------------------------------
# Server (POINTLESSQL_SERVER_*)
# ---------------------------------------------------------------------------

# Listen address and port for the PointlesSQL web server.
# POINTLESSQL_SERVER_HOST=127.0.0.1
# POINTLESSQL_SERVER_PORT=8000

# Public base URL used for OIDC callback URIs and links in emails.
# Set this when running behind a reverse proxy or inside Docker.
# POINTLESSQL_SERVER_BASE_URL=https://pql.example.com

# ---------------------------------------------------------------------------
# soyuz-catalog upstream (POINTLESSQL_SOYUZ_*)
# ---------------------------------------------------------------------------

# soyuz-catalog server URL (the UC REST API backend).
# POINTLESSQL_SOYUZ_CATALOG_URL=http://127.0.0.1:8080

# ---------------------------------------------------------------------------
# Database (POINTLESSQL_DB_*)
# ---------------------------------------------------------------------------

# SQLAlchemy database URL for PointlesSQL's own metadata
# (users, sessions, audit log — NOT the lakehouse catalog).
# Default since BUG-grand-09 fix: SQLite file anchored at the
# repo root (``<repo>/pointlessql.db``), independent of the CWD
# the server was started from.  Override here when a different
# location is needed (Docker volumes, multi-tenant installs).
# For Postgres: postgresql+psycopg://user:pass@host:5432/dbname
# POINTLESSQL_DB_URL=sqlite:///./pointlessql.db

# ---------------------------------------------------------------------------
# Auth (POINTLESSQL_AUTH_*)
# ---------------------------------------------------------------------------

# Secret key for JWT signing. CHANGE THIS IN PRODUCTION.
# POINTLESSQL_AUTH_SECRET_KEY=change-me-in-production

# Optional grace-window previous signing key (Sprint 46). Set
# during rotation so outstanding cookies still verify while
# new tokens are signed with the primary key; drop after the
# window in POINTLESSQL_AUTH_JWT_EXPIRY_HOURS elapses.
# POINTLESSQL_AUTH_SECRET_KEY_PREVIOUS=

# JWT token lifetime in hours (default: 168 = 7 days).
# POINTLESSQL_AUTH_JWT_EXPIRY_HOURS=168

# ---------------------------------------------------------------------------
# Jupyter (POINTLESSQL_JUPYTER_*)
# ---------------------------------------------------------------------------

# Enable or disable the embedded JupyterLab subprocess.
# POINTLESSQL_JUPYTER_ENABLED=true

# Port for the embedded JupyterLab server.
# POINTLESSQL_JUPYTER_PORT=8888

# Workspace root for both the JupyterLab subprocess and the
# Papermill executor. Relative paths anchor to the startup CWD.
# POINTLESSQL_JUPYTER_NOTEBOOKS_DIR=notebooks

# Per-run ceiling (seconds) for the Papermill executor.
# POINTLESSQL_JUPYTER_EXECUTE_TIMEOUT_SECONDS=300

# ---------------------------------------------------------------------------
# Delta compute engine (POINTLESSQL_DELTA_*)
# ---------------------------------------------------------------------------

# Compute engine for the PQL DataFrame bridge. Currently only
# ``pandas`` is supported; reserved for future ``spark`` / ``polars``.
# POINTLESSQL_DELTA_ENGINE=pandas

# ---------------------------------------------------------------------------
# OIDC / OAuth2 (POINTLESSQL_OIDC_* — optional, leave unset to use local auth)
# ---------------------------------------------------------------------------

# OIDC discovery URL (e.g. https://accounts.google.com/.well-known/openid-configuration).
# POINTLESSQL_OIDC_DISCOVERY_URL=

# OAuth2 client ID registered with the OIDC provider.
# POINTLESSQL_OIDC_CLIENT_ID=

# OAuth2 client secret (optional — omit for public / PKCE-only clients).
# POINTLESSQL_OIDC_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Logging (POINTLESSQL_LOG_*)
# ---------------------------------------------------------------------------

# Python logging level (DEBUG / INFO / WARNING / ERROR).
# POINTLESSQL_LOG_LEVEL=INFO

# Output format. ``text`` for human-readable console, ``json`` for
# structured log ingestion.
# POINTLESSQL_LOG_FORMAT=text

# ---------------------------------------------------------------------------
# Scheduler (POINTLESSQL_SCHEDULER_*)
# ---------------------------------------------------------------------------

# Master toggle + loop cadence + global concurrency ceiling.
# POINTLESSQL_SCHEDULER_ENABLED=true
# POINTLESSQL_SCHEDULER_TICK_SECONDS=30
# POINTLESSQL_SCHEDULER_MAX_CONCURRENT_RUNS=4

# ---------------------------------------------------------------------------
# Audit log retention (POINTLESSQL_AUDIT_* — Sprint 48)
# ---------------------------------------------------------------------------

# Age cutoff for the periodic audit-cleanup sweep (days). Rows
# whose ``created_at`` is older than this cutoff are deleted by
# the retention loop. Set to 0 to keep every row forever.
# POINTLESSQL_AUDIT_RETENTION_DAYS=365

# Sweep cadence in seconds (default: once per day).
# POINTLESSQL_AUDIT_CLEANUP_INTERVAL_SECONDS=86400

# ---------------------------------------------------------------------------
# Rate limiting on /auth/* (POINTLESSQL_RATE_LIMIT_* — Sprint 43)
# ---------------------------------------------------------------------------

# POINTLESSQL_RATE_LIMIT_ENABLED=true
# POINTLESSQL_RATE_LIMIT_LOGIN_IP_COUNT=10
# POINTLESSQL_RATE_LIMIT_LOGIN_IP_WINDOW_S=600
# POINTLESSQL_RATE_LIMIT_LOGIN_EMAIL_COUNT=5
# POINTLESSQL_RATE_LIMIT_LOGIN_EMAIL_WINDOW_S=600
# POINTLESSQL_RATE_LIMIT_REGISTER_IP_COUNT=5
# POINTLESSQL_RATE_LIMIT_REGISTER_IP_WINDOW_S=3600
# POINTLESSQL_RATE_LIMIT_OIDC_IP_COUNT=20
# POINTLESSQL_RATE_LIMIT_OIDC_IP_WINDOW_S=600
# POINTLESSQL_RATE_LIMIT_TRUST_X_FORWARDED_FOR=false

# ---------------------------------------------------------------------------
# Docker Compose host ports (not POINTLESSQL_ prefixed — used in
# docker-compose.yml port mappings only)
# ---------------------------------------------------------------------------

# SOYUZ_HOST_PORT=8080
# PQL_HOST_PORT=8000
# JUPYTER_HOST_PORT=8888
# POSTGRES_HOST_PORT=5432
