{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["frontend/js/**/*.js", "frontend/js/**/*.mjs"],
  "exclude": ["node_modules", ".venv", "dist", "build"]
}
